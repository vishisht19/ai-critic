# At least one of the following API keys is required (or run Ollama locally)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Force a specific provider: anthropic | openai | ollama (default: auto-detect)
# LLM_PROVIDER=

# Ollama settings (only needed if using Ollama)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# LangSmith tracing (optional)
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=commit-critic
